# TalentIntel 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不应提交到 Git!

# 代理配置方式1: 完整的JSON格式配置
# PROXY_CONFIG_JSON='{"proxies": [{"url": "http://user:pass@host:port"}, {"url": "http://user2:pass2@host2:port2"}]}'

# 代理配置方式2: 单个代理URL (简单场景)
PROXY_URL=http://username:password@proxy.example.com:8080

# 代理配置方式3: 配置文件路径 (默认: config/proxies.yaml)
# PROXY_CONFIG_FILE=config/proxies.yaml

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 可选: SSL验证开关 (生产环境应保持开启)
# 设置为 "true" 启用验证, "false" 禁用 (不推荐)
SSL_VERIFY=true

# 可选: 请求超时时间(秒)
REQUEST_TIMEOUT=20

# 可选: 请求间隔随机范围(秒)
MIN_DELAY=5
MAX_DELAY=12
